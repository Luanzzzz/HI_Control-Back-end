# ============================================================================
# AMBIENTE DE PRODUÇÃO - HI-CONTROL API
# ============================================================================
# ⚠️ ATENÇÃO: Este arquivo NÃO deve estar no servidor.
# Em produção, usar SECRETS DO HOSTING (Vercel, Railway, AWS Secrets Manager)
#
# Este template serve APENAS como referência de variáveis necessárias.
# ============================================================================

# ----------------------------------------------------------------------------
# APLICAÇÃO
# ----------------------------------------------------------------------------
APP_NAME=Hi-Control API
DEBUG=false                                   # ⚠️ OBRIGATÓRIO false em produção
ENVIRONMENT=production

# ----------------------------------------------------------------------------
# SEGURANÇA - PRODUÇÃO
# ----------------------------------------------------------------------------
# ⚠️ CRÍTICO: Gerar chave ÚNICA para produção, NUNCA reutilizar de dev/homolog
# Gerar com: openssl rand -hex 32
SECRET_KEY=<GERAR_CHAVE_PRODUCAO_UNICA>

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------------------------
# CORS ORIGINS (produção)
# ----------------------------------------------------------------------------
# ✅ Deve incluir todas as origens do frontend que fará requisições
CORS_ORIGINS=["https://hi-control.vercel.app", "https://site-hi-control.vercel.app"]

# ----------------------------------------------------------------------------
# BANCO DE DADOS - NÃO USAR SQLite EM PRODUÇÃO
# ----------------------------------------------------------------------------
# Usar PostgreSQL gerenciado (Supabase, AWS RDS, Railway)
DATABASE_URL=postgresql://user:pass@host:5432/hicontrol_production

# ----------------------------------------------------------------------------
# SUPABASE - PROJETO DE PRODUÇÃO
# ----------------------------------------------------------------------------
# ⚠️ PROJETO SEPARADO: Criar projeto Supabase EXCLUSIVO para produção
SUPABASE_URL=https://projeto-prod.supabase.co
SUPABASE_KEY=<ANON_KEY_PROD>
SUPABASE_SERVICE_KEY=<SERVICE_KEY_PROD>       # ⚠️ NUNCA expor no frontend!

# ----------------------------------------------------------------------------
# MÓDULOS - PRODUÇÃO
# ----------------------------------------------------------------------------
# ⚠️ CRÍTICO: OBRIGATÓRIO false em produção
# Sistema deve bloquear startup se esta variável for true em produção
DISABLE_MODULE_CHECK=false

# ----------------------------------------------------------------------------
# CRIPTOGRAFIA - PRODUÇÃO
# ----------------------------------------------------------------------------
# ⚠️ CRÍTICO: Gerar chave ÚNICA para produção
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ATENÇÃO: Se alterar esta chave, todos os certificados precisam ser re-criptografados
CERTIFICATE_ENCRYPTION_KEY=<GERAR_FERNET_KEY_PRODUCAO_UNICA>

# ----------------------------------------------------------------------------
# SEFAZ - PRODUÇÃO
# ----------------------------------------------------------------------------
# ⚠️ CRÍTICO: Ambiente de PRODUÇÃO - Notas fiscais REAIS
SEFAZ_AMBIENTE=producao
PYNFE_HOMOLOGACAO=false
# ⚠️ Esta flag DEVE ser true para permitir emissão em produção
ALLOW_PRODUCTION_EMISSION=true

# ----------------------------------------------------------------------------
# GOOGLE OAUTH - PRODUÇÃO
# ----------------------------------------------------------------------------
# Projeto Google Cloud EXCLUSIVO para produção
GOOGLE_CLIENT_ID=<CLIENT_ID_PROD>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<CLIENT_SECRET_PROD>
GOOGLE_REDIRECT_URI=https://api.hicontrol.com.br/api/v1/drive/auth/callback

# ----------------------------------------------------------------------------
# ALLOWED HOSTS
# ----------------------------------------------------------------------------
ALLOWED_HOSTS=api.hicontrol.com.br,app.hicontrol.com.br

# ============================================================================
# CHECKLIST DE SEGURANÇA ANTES DE DEPLOY EM PRODUÇÃO:
# ============================================================================
# [ ] SECRET_KEY gerada com openssl rand -hex 32 (única)
# [ ] CERTIFICATE_ENCRYPTION_KEY gerada com Fernet (única)
# [ ] SUPABASE_SERVICE_KEY rotacionada (não reutilizar de dev/homolog)
# [ ] GOOGLE_CLIENT_SECRET rotacionado
# [ ] DEBUG=false
# [ ] DISABLE_MODULE_CHECK=false
# [ ] SEFAZ_AMBIENTE=producao
# [ ] ALLOW_PRODUCTION_EMISSION=true (apenas se for emitir notas reais)
# [ ] Variáveis configuradas como SECRETS do hosting (não em arquivo .env)
# [ ] Certificado digital A1 de PRODUÇÃO (não usar cert de homologação)
# [ ] Executado checklist completo de testes em homologação
# [ ] Backup do banco de dados configurado
# [ ] Monitoramento (Sentry, Datadog) configurado
# ============================================================================
