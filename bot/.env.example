# ============================================
# Bot de Busca Automática - Hi-Control
# ============================================

# Supabase (OBRIGATÓRIO)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-key-aqui

# Bot - Agendamento
BOT_INTERVALO_MINUTOS=60
BOT_EXECUTAR_AGORA=true
BOT_DIAS_RETROATIVOS=30

# Bot - Base Nacional NFS-e
BASE_NACIONAL_URL=https://sefin.nfse.gov.br/sefinnacional
BASE_NACIONAL_URL_HOMOLOGACAO=https://sefin.producaorestrita.nfse.gov.br/sefinnacional
BASE_NACIONAL_HOMOLOGACAO=false
BASE_NACIONAL_TIMEOUT=60

# Bot - Logging
BOT_LOG_LEVEL=INFO
BOT_MAX_RETRIES=3
BOT_RETRY_DELAY=5
BOT_TIMEOUT=60

# Certificado (opcional)
CERTIFICATE_ENCRYPTION_KEY=sua-chave-fernet-aqui
