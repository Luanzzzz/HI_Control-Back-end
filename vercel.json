{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "app/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "app/main.py"
    }
  ],
  "trailingSlash": false
}