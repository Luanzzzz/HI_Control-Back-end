# Application
PROJECT_NAME=Hi-Control API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development

# Segurança (ALTERAR EM PRODUÇÃO!)
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://hi-control.vercel.app

# Supabase Configuration
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# Future PostgreSQL (para notas fiscais - fase 2)
# POSTGRES_URL=postgresql://user:pass@localhost:5432/hicontrol_notas
# POSTGRES_USER=hicontrol_user
# POSTGRES_PASSWORD=senha_segura
# POSTGRES_DB=hicontrol_notas

# SEFAZ Configuration
# Ambiente: "producao" ou "homologacao"
# IMPORTANTE: Dados reais so aparecem em producao
SEFAZ_AMBIENTE=producao

# NFS-e Configuration (APIs Municipais)
# Ambiente: "producao" ou "homologacao"
NFSE_AMBIENTE=producao
NFSE_TIMEOUT=60

# ===================================================
# Google OAuth (para Google Drive integration)
# ===================================================
# Obtenha em: https://console.cloud.google.com/apis/credentials
# 1. Crie um projeto no Google Cloud Console
# 2. Ative a Google Drive API
# 3. Crie credenciais OAuth 2.0 (tipo: Aplicativo Web)
# 4. Adicione a URI de redirecionamento abaixo
GOOGLE_CLIENT_ID=931689312133-47neph5andjmodm6l4ti9ppc6po5l37n.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=https://backend-gamma-cyan-75.vercel.app/api/v1/drive/callback

# ===================================================
# Chave de encriptação para certificados e tokens
# ===================================================
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CERTIFICATE_ENCRYPTION_KEY=sua-chave-fernet-aqui

# Allowed Hosts
ALLOWED_HOSTS=*
