# Application
PROJECT_NAME=Hi-Control API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development

# Segurança (ALTERAR EM PRODUÇÃO!)
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://hi-control.vercel.app

# Supabase Configuration
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# Future PostgreSQL (para notas fiscais - fase 2)
# POSTGRES_URL=postgresql://user:pass@localhost:5432/hicontrol_notas
# POSTGRES_USER=hicontrol_user
# POSTGRES_PASSWORD=senha_segura
# POSTGRES_DB=hicontrol_notas

# SEFAZ Configuration
# Ambiente: "producao" ou "homologacao"
# IMPORTANTE: Dados reais so aparecem em producao
SEFAZ_AMBIENTE=producao

# NFS-e Configuration (APIs Municipais)
# Ambiente: "producao" ou "homologacao"
NFSE_AMBIENTE=producao
NFSE_TIMEOUT=60

# Google OAuth (para Google Drive integration)
# GOOGLE_CLIENT_ID=seu-client-id-aqui
# GOOGLE_CLIENT_SECRET=seu-client-secret-aqui
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/drive/auth/callback

# Allowed Hosts
ALLOWED_HOSTS=*
