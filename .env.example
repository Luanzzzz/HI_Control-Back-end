# ============================================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE - HI-CONTROL API
# ============================================================================
# Este arquivo serve como TEMPLATE para configuração do ambiente.
# NUNCA committar arquivo .env com valores reais no Git!
#
# INSTRUÇÕES:
# 1. Copiar este arquivo para .env (ambiente local)
# 2. Preencher com valores reais
# 3. Para produção, usar secrets do hosting (Vercel, Railway, AWS, etc.)
# ============================================================================

# ----------------------------------------------------------------------------
# APLICAÇÃO
# ----------------------------------------------------------------------------
APP_NAME=Hi-Control API
DEBUG=true                                    # false em produção
ENVIRONMENT=development                       # development | staging | production

# ----------------------------------------------------------------------------
# SEGURANÇA - ATENÇÃO: GERAR VALORES ÚNICOS PARA CADA AMBIENTE
# ----------------------------------------------------------------------------
# SECRET_KEY: Chave mestra para assinatura JWT
# GERAR COM: openssl rand -hex 32
SECRET_KEY=gerar-com-openssl-rand-hex-32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------------------------
# CORS ORIGINS (separados por vírgula, formato JSON array)
# ----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ----------------------------------------------------------------------------
# BANCO DE DADOS (LOCAL - APENAS DESENVOLVIMENTO)
# ----------------------------------------------------------------------------
# Para desenvolvimento local com SQLite (não usar em produção)
DATABASE_URL=sqlite+aiosqlite:///./hicontrol.db

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Obter em: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-anon-key-aqui                # Anon key (pública)
SUPABASE_SERVICE_KEY=sua-service-key-aqui     # Service role key (NUNCA expor no frontend!)

# ----------------------------------------------------------------------------
# MÓDULOS - CONTROLE DE ACESSO POR PLANO
# ----------------------------------------------------------------------------
# ⚠️ ATENÇÃO: Definir como "false" ou remover em PRODUÇÃO!
# Esta flag permite acesso a todos os módulos sem validação de plano.
# Usar APENAS em desenvolvimento local.
DISABLE_MODULE_CHECK=true

# ----------------------------------------------------------------------------
# CRIPTOGRAFIA DE CERTIFICADOS DIGITAIS A1
# ----------------------------------------------------------------------------
# ⚠️ CRÍTICO: Gerar chave única para cada ambiente
# GERAR COM: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CERTIFICATE_ENCRYPTION_KEY=gerar-com-cryptography-fernet

# ----------------------------------------------------------------------------
# PYNFE - INTEGRAÇÃO SEFAZ
# ----------------------------------------------------------------------------
# Ambiente SEFAZ: producao | homologacao
SEFAZ_AMBIENTE=homologacao
PYNFE_HOMOLOGACAO=true

# ----------------------------------------------------------------------------
# PROTEÇÃO CONTRA EMISSÃO ACIDENTAL EM PRODUÇÃO
# ----------------------------------------------------------------------------
# Esta flag protege contra emissão acidental de notas fiscais válidas durante:
# - Testes automatizados (pytest, CI/CD)
# - Desenvolvimento local
# - Ambientes de staging
#
# REGRAS DE SEGURANÇA:
# - Se SEFAZ_AMBIENTE=homologacao → Emissão sempre permitida (sem riscos)
# - Se SEFAZ_AMBIENTE=producao + ALLOW_PRODUCTION_EMISSION=false → BLOQUEADO
# - Se SEFAZ_AMBIENTE=producao + ALLOW_PRODUCTION_EMISSION=true → Permitido
# - Se ENVIRONMENT=test → NUNCA permite emissão em produção (mesmo se flag=true)
#
# ⚠️ IMPORTANTE:
# - Uma nota emitida em produção é VÁLIDA na Receita Federal
# - Cancelamento requer processo formal e pode gerar problemas fiscais
# - Em produção, configurar ALLOW_PRODUCTION_EMISSION=true apenas quando necessário
#
# VALORES:
# - false: Bloqueia emissão em produção (recomendado para dev/staging)
# - true: Permite emissão em produção (apenas em ambiente de produção validado)
ALLOW_PRODUCTION_EMISSION=false

# ----------------------------------------------------------------------------
# GOOGLE OAUTH (GOOGLE DRIVE INTEGRATION)
# ----------------------------------------------------------------------------
# Obter em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret-aqui
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/drive/auth/callback

# ----------------------------------------------------------------------------
# ALLOWED HOSTS (OPCIONAL)
# ----------------------------------------------------------------------------
ALLOWED_HOSTS=*

# ============================================================================
# NOTAS DE SEGURANÇA:
# ============================================================================
# 1. NUNCA versionar arquivo .env com valores reais no Git
# 2. Rotacionar credenciais periodicamente (especialmente antes de deploy)
# 3. Usar secrets do hosting em produção (Vercel Environment Variables, etc.)
# 4. CERTIFICATE_ENCRYPTION_KEY: Se alterada, re-criptografar certificados
# 5. SUPABASE_SERVICE_KEY: Bypassa RLS - usar APENAS no backend
# ============================================================================
